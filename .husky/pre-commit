#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run lint:fix in magni directory
cd magni || exit 1

# Run lint:fix and check output for errors (not warnings)
# ESLint exits with code 1 even for warnings, so we need to check the output
# Disable exit on error for the rest of the script to handle non-critical failures
set +e
LINT_OUTPUT=$(pnpm run lint:fix 2>&1)
LINT_EXIT=$?

# Display the lint output
echo "$LINT_OUTPUT"

# Check if there are actual errors (not just warnings)
# ESLint output format: "✖ X problems (Y errors, Z warnings)"
# Match patterns like "1 error", "2 errors", etc. but not "0 errors"
if echo "$LINT_OUTPUT" | grep -qE "([1-9][0-9]* error|[1-9][0-9]* errors)"; then
    echo ""
    echo "❌ Linting failed with errors! Please fix the errors before committing."
    exit 1
fi

# If we get here, there are only warnings (or no issues), allow commit
echo ""
echo "✅ Linting passed (warnings are allowed)"

# Return to root directory for git commands
cd .. || exit 1

# Stage any files that were auto-fixed by lint:fix
# This is safe even if no files were changed
git add -u 2>/dev/null || true

STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^modi/.*\.go$')
if [ -n "$STAGED_GO_FILES" ]; then
    echo "Running golangci-lint on staged Go files in modi/..."
    
    # Add Go bin to PATH if it exists
    if [ -d "$HOME/go/bin" ]; then
        export PATH="$PATH:$HOME/go/bin"
    fi
    
    # Try to find golangci-lint in common locations
    GOLANGCI_LINT=""
    if command -v golangci-lint >/dev/null 2>&1; then
        GOLANGCI_LINT="golangci-lint"
    elif [ -f "$HOME/go/bin/golangci-lint" ]; then
        GOLANGCI_LINT="$HOME/go/bin/golangci-lint"
    elif command -v go >/dev/null 2>&1 && [ -f "$(go env GOPATH)/bin/golangci-lint" ]; then
        GOLANGCI_LINT="$(go env GOPATH)/bin/golangci-lint"
    fi
    
    # Check if golangci-lint is available
    if [ -z "$GOLANGCI_LINT" ]; then
        echo "Warning: golangci-lint is not installed or not in PATH"
        echo "Skipping Go lint check. Install with: curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/master/install.sh | sh -s -- -b \$(go env GOPATH)/bin latest"
    else
        cd modi || exit 0
        if ! "$GOLANGCI_LINT" run --timeout=5m ./...; then
            echo ""
            echo "❌ Go linting failed! Please fix the errors before committing."
            echo "You can run 'make lint' in the modi/ directory to see the errors."
            exit 1
        fi
        echo "✅ Go linting passed!"
    fi
fi

